[configuration]
entry_symbol = "station_mirny_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]
windows.debug.x86_64 = "res://gdextension/bin/station_mirny.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://gdextension/bin/station_mirny.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://gdextension/bin/libstation_mirny.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://gdextension/bin/libstation_mirny.linux.template_release.x86_64.so"
