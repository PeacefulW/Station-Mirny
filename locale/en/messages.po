msgstr "Gravity radius:"

msgid "UI_WORLDGEN_MOUNTAINS_GRAVITY_RADIUS_DESC"
msgstr "Sets how far each mountain anchor pulls nearby terrain. Higher values widen the area influenced by each mass."

msgid "UI_WORLDGEN_MOUNTAINS_FOOT_BAND"
msgstr "Foot band width:"

msgid "UI_WORLDGEN_MOUNTAINS_FOOT_BAND_DESC"
msgstr "Sets the width of the transition band at the mountain foot. Higher values create a broader, softer transition from flats into slopes."

msgid "UI_WORLDGEN_MOUNTAINS_INTERIOR_MARGIN"
msgstr "Interior margin:"

msgid "UI_WORLDGEN_MOUNTAINS_INTERIOR_MARGIN_DESC"
msgstr "Controls how deep the dense inner body of a ridge extends. Higher values make the mountain core thicker."

msgid "UI_WORLDGEN_MOUNTAINS_LATITUDE_INFLUENCE"
msgstr "Latitude influence:"

msgid "UI_WORLDGEN_MOUNTAINS_LATITUDE_INFLUENCE_DESC"
msgstr "Controls how strongly latitude affects mountain placement. Zero removes the latitude bias, while positive and negative values shift generation in different ways."

